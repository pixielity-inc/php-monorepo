{
  "name": "pixielity/octane-module",
  "description": "Laravel Octane integration module with simplified server management commands for production-grade headless API backends",
  "type": "library",
  "keywords": [
    "laravel",
    "octane",
    "roadrunner",
    "frankenphp",
    "server",
    "performance",
    "api",
    "headless",
    "pixielity"
  ],
  "license": "MIT",
  "authors": [
    {
      "name": "Pixielity Inc",
      "email": "hello@pixielity.com"
    }
  ],
  "require": {
    "php": "^8.4",
    "illuminate/support": "^13.0",
    "illuminate/console": "^13.0",
    "laravel/octane": "^2.17"
  },
  "require-dev": {
    "phpunit/phpunit": "^13.0|^12.0"
  },
  "autoload": {
    "psr-4": {
      "Pixielity\\Octane\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Pixielity\\Octane\\Providers\\OctaneServiceProvider"
      ]
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
