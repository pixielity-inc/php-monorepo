{
  "name": "pixielity/laravel-support",
  "description": "Support utilities and helpers for Pixielity packages",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "support",
    "helpers",
    "utilities",
    "laravel",
    "pixielity"
  ],
  "authors": [
    {
      "name": "Pixielity Team",
      "email": "dev@pixielity.com"
    }
  ],
  "require": {
    "php": "^8.4|^8.5"
  },
  "autoload": {
    "psr-4": {
      "Pixielity\\Support\\": "src/"
    },
    "files": [
      "src/Helpers/Support.php",
      "src/Helpers/Polyfills.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Pixielity\\Support\\Tests\\": "tests/"
    }
  },
  "config": {
    "sort-packages": true,
    "preferred-install": "dist",
    "optimize-autoloader": true,
    "allow-plugins": {}
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "mockery/mockery": "^1.6",
    "orchestra/testbench": "^10.0"
  },
  "homepage": "https://gitlab.com/pixielity/laravel/framework/support",
  "support": {
    "issues": "https://gitlab.com/pixielity/laravel/framework/support/-/issues",
    "source": "https://gitlab.com/pixielity/laravel/framework/support"
  }
}
