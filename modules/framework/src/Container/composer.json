{
    "name": "pixielity/laravel-container",
    "description": "Dependency injection container utilities and extensions",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "container",
        "dependency-injection",
        "ioc",
        "laravel",
        "pixielity"
    ],
    "authors": [
        {
            "name": "Pixielity Team",
            "email": "dev@pixielity.com"
        }
    ],
    "require": {
        "php": "^8.4|^8.5",
        "illuminate/container": "^13.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Pixielity\\Container\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Pixielity\\Container\\Providers\\ContainerServiceProvider"
            ]
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^10.0"
    },
    "homepage": "https://gitlab.com/pixielity/laravel/framework/container",
    "support": {
        "issues": "https://gitlab.com/pixielity/laravel/framework/container/-/issues",
        "source": "https://gitlab.com/pixielity/laravel/framework/container"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {}
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
