{
    "name": "pixielity/laravel-enum",
    "description": "Modern PHP 8.1+ enum system with metadata, attributes, and helper traits",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "enum",
        "php81",
        "attributes",
        "metadata",
        "laravel",
        "pixielity"
    ],
    "authors": [
        {
            "name": "Pixielity Team",
            "email": "dev@pixielity.com"
        }
    ],
    "require": {
        "php": "^8.4|^8.5"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "orchestra/testbench": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Pixielity\\Enum\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Pixielity\\Enum\\Tests\\": "tests/"
        }
    },
    "homepage": "https://gitlab.com/pixielity/laravel/framework/enum",
    "support": {
        "issues": "https://gitlab.com/pixielity/laravel/framework/enum/-/issues",
        "source": "https://gitlab.com/pixielity/laravel/framework/enum"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {}
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
