{
    "name": "pixielity/laravel-foundation",
    "description": "Foundation module for Pixielity Laravel headless API backend - provides custom Application class, root route handlers, and base API structure",
    "type": "library",
    "keywords": [
        "laravel",
        "module",
        "foundation",
        "api",
        "headless",
        "pixielity"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Pixielity Inc",
            "email": "hello@pixielity.com"
        }
    ],
    "require": {
        "php": "^8.4|^8.5",
        "illuminate/support": "^13.0",
        "illuminate/routing": "^13.0",
        "pixielity/laravel-discovery": "*",
        "pixielity/laravel-framework": "@dev",
        "maantje/react-email": "^1.0",
        "jaybizzle/crawler-detect": "^1.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Pixielity\\Foundation\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Pixielity\\Foundation\\Tests\\": "tests/",
            "Pixielity\\Foundation\\Scripts\\": "scripts/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Pixielity\\Foundation\\Providers\\FoundationServiceProvider"
            ],
            "aliases": {}
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "path",
            "url": "../*"
        }
    ],
    "config": {
        "allow-plugins": {
            "olvlvl/composer-attribute-collector": true
        }
    },
    "scripts": {
        "cache:clear": "Pixielity\\Foundation\\Scripts\\CacheScripts::clear",
        "cache:warm": "Pixielity\\Foundation\\Scripts\\CacheScripts::warm",
        "cache:clean": "Pixielity\\Foundation\\Scripts\\CacheScripts::clean",
        "test": "Pixielity\\Foundation\\Scripts\\TestScripts::run",
        "test:coverage": "Pixielity\\Foundation\\Scripts\\TestScripts::coverage",
        "test:parallel": "Pixielity\\Foundation\\Scripts\\TestScripts::parallel",
        "test:filter": "Pixielity\\Foundation\\Scripts\\TestScripts::filter",
        "lint": "Pixielity\\Foundation\\Scripts\\LintScripts::check",
        "lint:fix": "Pixielity\\Foundation\\Scripts\\LintScripts::fix",
        "analyse": "Pixielity\\Foundation\\Scripts\\AnalyseScripts::run",
        "analyse:baseline": "Pixielity\\Foundation\\Scripts\\AnalyseScripts::baseline",
        "refactor": "Pixielity\\Foundation\\Scripts\\RefactorScripts::dryRun",
        "refactor:fix": "Pixielity\\Foundation\\Scripts\\RefactorScripts::apply",
        "insights": "Pixielity\\Foundation\\Scripts\\InsightsScripts::run",
        "insights:fix": "Pixielity\\Foundation\\Scripts\\InsightsScripts::fix",
        "env:dev": "Pixielity\\Foundation\\Scripts\\EnvScripts::dev",
        "env:testing": "Pixielity\\Foundation\\Scripts\\EnvScripts::testing",
        "env:prod": "Pixielity\\Foundation\\Scripts\\EnvScripts::prod",
        "env:status": "Pixielity\\Foundation\\Scripts\\EnvScripts::status",
        "setup:env": "Pixielity\\Foundation\\Scripts\\EnvScripts::setup"
    }
}
