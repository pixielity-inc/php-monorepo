{
    "name": "pixielity/laravel-foundation",
    "description": "Foundation module for Pixielity Laravel headless API backend - provides custom Application class, root route handlers, and base API structure",
    "type": "library",
    "keywords": [
        "laravel",
        "module",
        "foundation",
        "api",
        "headless",
        "pixielity"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Pixielity Inc",
            "email": "hello@pixielity.com"
        }
    ],
    "require": {
        "php": "^8.4|^8.5",
        "illuminate/support": "^13.0",
        "illuminate/routing": "^13.0",
        "pixielity/laravel-discovery": "*",
        "pixielity/laravel-framework": "@dev",
        "maantje/react-email": "^1.0",
        "jaybizzle/crawler-detect": "^1.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Pixielity\\Foundation\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Pixielity\\Foundation\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Pixielity\\Foundation\\Providers\\FoundationServiceProvider"
            ],
            "aliases": {}
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "path",
            "url": "../*"
        }
    ],
    "config": {
        "allow-plugins": {
            "olvlvl/composer-attribute-collector": true
        }
    }
}
