# phpstan.neon — php-monorepo
# =============================================================================
#
# Root PHPStan configuration for the entire monorepo.
#
# PHPStan is a static analysis tool that finds bugs in PHP code without
# running it. It analyses type safety, undefined variables, dead code,
# and many other issues.
#
# Documentation: https://phpstan.org/config-reference
#
# Usage:
#   From repo root:          npm run analyse
#   From a workspace:        vendor/bin/phpstan analyse --no-progress
#   With baseline:           vendor/bin/phpstan analyse --generate-baseline
#   Single file:             vendor/bin/phpstan analyse src/MyClass.php
#   Clear result cache:      vendor/bin/phpstan clear-result-cache
#
# CI: This config is used by .github/workflows/ci.yml
# =============================================================================

includes:
    # -------------------------------------------------------------------------
    # Larastan — Laravel-aware PHPStan extension.
    #
    # Adds type stubs for Laravel facades, Eloquent models, helpers, macros,
    # and other Laravel-specific patterns that PHPStan cannot infer on its own.
    #
    # Install: composer require --dev larastan/larastan
    # Docs:    https://github.com/larastan/larastan
    # -------------------------------------------------------------------------
    # - applications/api-app/vendor/larastan/larastan/extension.neon

parameters:

    # =========================================================================
    # ANALYSIS PATHS
    # =========================================================================
    #
    # Directories and files PHPStan will scan.
    # Paths are relative to this config file (the repo root).
    # =========================================================================
    paths:
        - modules
        - applications

    # =========================================================================
    # STRICTNESS LEVEL
    # =========================================================================
    #
    # PHPStan levels range from 0 (loosest) to 10 (strictest).
    #
    # Level summary:
    #   0  — Basic checks: unknown classes, functions, methods
    #   1  — Possibly undefined variables, unknown magic methods
    #   2  — Unknown methods on $this in anonymous classes
    #   3  — Return types, types assigned to properties
    #   4  — Dead code, always-true conditions
    #   5  — Argument types passed to methods and functions
    #   6  — Return type of methods (missing @return)
    #   7  — Union types, iterable types
    #   8  — Nullable types, strict comparison
    #   9  — Mixed types — no implicit mixed allowed
    #  10  — Strictest — everything must be typed
    #
    # Level 8 is a solid production baseline that catches real bugs without
    # being so strict it generates noise on well-written code.
    # Raise to 9 or 10 incrementally as the codebase matures.
    # =========================================================================
    level: 8

    # =========================================================================
    # BUILD / CACHE DIRECTORY
    # =========================================================================
    #
    # PHPStan stores its result cache here to speed up subsequent runs.
    # This directory should be added to .gitignore.
    # =========================================================================
    tmpDir: build/phpstan

    # =========================================================================
    # EXCLUDED PATHS
    # =========================================================================
    #
    # Glob patterns for files and directories to skip entirely.
    # PHPStan will not analyse these files even if they are in the paths above.
    # =========================================================================
    excludePaths:
        # Never analyse third-party code.
        - "*/vendor/*"

        # Test files are excluded from the main analysis pass.
        # Run a separate PHPStan config for tests if needed.
        - "*/tests/*"
        - "*/Tests/*"

        # Laravel compiled/cached files — auto-generated, not hand-written.
        - "*/bootstrap/cache/*"
        - "*/storage/*"

        # Database migrations — intentionally use dynamic column definitions.
        - "*/database/migrations/*"

        # IDE helper files generated by barryvdh/laravel-ide-helper.
        - "*/_ide_helper.php"
        - "*/_ide_helper_models.php"

    # =========================================================================
    # IGNORED ERROR PATTERNS
    # =========================================================================
    #
    # Regex patterns for error messages to suppress.
    # Use sparingly — prefer fixing the root cause over ignoring errors.
    # Each entry should have a comment explaining WHY it is ignored.
    #
    # Format:
    #   - message: '#regex pattern#'
    #     path: optional/path/to/file.php   # limit to specific file
    #     count: 3                           # expected number of occurrences
    # =========================================================================
    ignoreErrors:

        # -----------------------------------------------------------------------
        # Laravel / Illuminate internals
        # -----------------------------------------------------------------------
        # PHPStan cannot fully resolve Illuminate types without Larastan.
        # Once larastan/larastan is installed and the extension.neon include
        # above is uncommented, most of these can be removed.
        - "#Illuminate\\\\#"
        - "#Laravel\\\\#"

        # -----------------------------------------------------------------------
        # Iterable type hints
        # -----------------------------------------------------------------------
        # These are low-priority warnings on utility/helper code.
        # Address these incrementally when refactoring affected files.
        - "#has no value type specified in iterable type array#"
        - "#with no value type specified in iterable type array#"
        - "#does not specify its types#"

        # -----------------------------------------------------------------------
        # Type narrowing — PHPStan being overly strict on already-narrowed types
        # -----------------------------------------------------------------------
        # These occur when a variable has already been narrowed by a prior check
        # but PHPStan still flags the redundant guard.
        - "#Call to function is_string\\(\\) with string will always evaluate to true#"
        - "#Expression on left side of \\?\\? is not nullable#"

    # =========================================================================
    # PARALLEL PROCESSING
    # =========================================================================
    #
    # PHPStan can analyse files in parallel to speed up large codebases.
    # Adjust based on available CPU cores in your CI environment.
    # =========================================================================
    parallel:
        # Maximum number of parallel worker processes.
        # Set to 1 to disable parallelism (useful for debugging).
        maximumNumberOfProcesses: 8

        # Minimum number of files per worker job.
        # Smaller values = more parallelism but more overhead.
        minimumNumberOfJobsPerProcess: 2

    # =========================================================================
    # TYPE COVERAGE (optional — requires phpstan/phpstan-strict-rules)
    # =========================================================================
    #
    # Uncomment to enforce a minimum percentage of typed code.
    # Useful for tracking progress when adding types to a legacy codebase.
    # =========================================================================
    # coverage:
    #     returnTypes: 80    # % of methods that must have return types
    #     paramTypes: 80     # % of parameters that must have types
    #     propertyTypes: 80  # % of properties that must have types

    # =========================================================================
    # BLEEDING EDGE (optional)
    # =========================================================================
    #
    # Enables checks that will become default in the next major PHPStan version.
    # Useful for staying ahead of deprecations. May produce false positives.
    # =========================================================================
    # bleedingEdge: true
