{
  "$schema": "https://getcomposer.org/schema.json",
  "name": "pixielity/api-app",
  "type": "project",
  "description": "Laravel 13 application — api-app.",
  "keywords": [
    "laravel",
    "framework",
    "application"
  ],
  "homepage": "https://github.com/pixielity-inc/php-monorepo",
  "license": "MIT",
  "authors": [
    {
      "name": "Your Name",
      "email": "you@example.com",
      "role": "Developer"
    }
  ],
  "require": {
    "php": "^8.4",
    "laravel/framework": "^13.0",
    "laravel/tinker": "^3.0",
    "nwidart/laravel-modules": "^13.0",
    "pixielity/laravel-framework": "*",
    "pixielity/laravel-foundation": "*",
    "pixielity/laravel-octane": "*",
    "pixielity/laravel-user": "*"
  },
  "require-dev": {
    "barryvdh/laravel-debugbar": "^4.1",
    "driftingly/rector-laravel": "^2.2",
    "fakerphp/faker": "^1.23",
    "larastan/larastan": "^3.9",
    "laravel/boost": "^2.0",
    "laravel/pail": "^1.2.5",
    "laravel/pint": "^1.29",
    "mockery/mockery": "^1.6",
    "nunomaduro/collision": "^8.6",
    "nunomaduro/phpinsights": "^2.14",
    "pestphp/pest": "^4.4",
    "pestphp/pest-plugin-laravel": "^4.1",
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^12.5.12",
    "rector/rector": "^2.3",
    "spatie/laravel-ray": "^1.43"
  },
  "suggest": {
    "laravel/cashier": "Stripe billing and subscription management",
    "laravel/cashier-paddle": "Paddle billing integration",
    "laravel/dusk": "Browser automation and testing",
    "laravel/envoy": "Task runner for remote servers",
    "laravel/folio": "Page-based routing for Laravel",
    "laravel/jetstream": "Application scaffolding with auth, teams, and more",
    "laravel/octane": "Supercharge application performance with Swoole or RoadRunner",
    "laravel/passport": "Full OAuth2 server implementation",
    "laravel/pennant": "Feature flags management",
    "laravel/pulse": "Real-time application performance monitoring",
    "laravel/reverb": "First-party WebSocket server",
    "laravel/scout": "Full-text search via Algolia, Meilisearch, or Typesense",
    "laravel/socialite": "OAuth authentication with social providers",
    "laravel/telescope": "Debug assistant and request inspector",
    "spatie/laravel-activitylog": "Log activity inside your Laravel app",
    "spatie/laravel-backup": "Back up your application",
    "spatie/laravel-medialibrary": "Associate files with Eloquent models",
    "spatie/laravel-permission": "Role and permission management",
    "spatie/laravel-query-builder": "Easily build Eloquent queries from API requests",
    "spatie/laravel-sluggable": "Generate slugs for Eloquent models",
    "spatie/laravel-translatable": "Making Eloquent models translatable",
    "barryvdh/laravel-ide-helper": "IDE helper for Laravel facades and models",
    "pestphp/pest": "Elegant PHP testing framework",
    "pestphp/pest-plugin-laravel": "Pest plugin for Laravel"
  },
  "autoload": {
    "files": [
      "vendor/attributes.php"
    ]
  },
  "scripts": {
    "_hooks": "── LIFECYCLE HOOKS ─────────────────────────────────",
    "post-install-cmd": [
      "Pixielity\\Scripts\\ComposerScripts::ensureRepositories"
    ],
    "post-update-cmd": [
      "Pixielity\\Scripts\\ComposerScripts::ensureRepositories",
      "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
    ],
    "post-autoload-dump": [
      "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
      "@php artisan package:discover --ansi"
    ],
    "post-root-package-install": [
      "@setup:env"
    ],
    "post-create-project-cmd": [
      "@setup:env",
      "php artisan key:generate --ansi"
    ],
    "pre-package-uninstall": [
      "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
    ],
    "_setup": "── SETUP ───────────────────────────────────────────────",
    "setup": [
      "@setup:env",
      "@docker:up",
      "composer install",
      "php artisan key:generate --ansi",
      "@migrate"
    ],
    "setup:env": "Pixielity\\Foundation\\Scripts\\EnvScripts::setup",
    "setup:quick": [
      "composer install",
      "@setup:env",
      "php artisan key:generate --ansi"
    ],
    "_env": "── ENVIRONMENT ─────────────────────────────────────────",
    "env:dev": "Pixielity\\Foundation\\Scripts\\EnvScripts::dev",
    "env:testing": "Pixielity\\Foundation\\Scripts\\EnvScripts::testing",
    "env:prod": "Pixielity\\Foundation\\Scripts\\EnvScripts::prod",
    "env:status": "Pixielity\\Foundation\\Scripts\\EnvScripts::status",
    "_dev": "── DEV SERVERS ─────────────────────────────────────────",
    "dev": [
      "Composer\\Config::disableProcessTimeout",
      "php artisan serve"
    ],
    "dev:octane": [
      "Composer\\Config::disableProcessTimeout",
      "php artisan octane:start --server=frankenphp --watch"
    ],
    "dev:full": [
      "Composer\\Config::disableProcessTimeout",
      "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185\" \"php artisan octane:start --server=frankenphp --watch\" \"php artisan queue:listen --tries=1 --timeout=0\" \"php artisan pail --timeout=0\" --names=octane,queue,logs --kill-others"
    ],
    "_octane": "── OCTANE ──────────────────────────────────────────────",
    "octane:start": "Pixielity\\Octane\\Scripts\\OctaneScripts::start",
    "octane:start:prod": "Pixielity\\Octane\\Scripts\\OctaneScripts::startProd",
    "octane:reload": "Pixielity\\Octane\\Scripts\\OctaneScripts::reload",
    "octane:stop": "Pixielity\\Octane\\Scripts\\OctaneScripts::stop",
    "octane:status": "Pixielity\\Octane\\Scripts\\OctaneScripts::status",
    "_database": "── DATABASE ────────────────────────────────────────────",
    "migrate": "Pixielity\\Database\\Scripts\\DatabaseScripts::migrate",
    "migrate:fresh": "Pixielity\\Database\\Scripts\\DatabaseScripts::fresh",
    "migrate:rollback": "Pixielity\\Database\\Scripts\\DatabaseScripts::rollback",
    "migrate:status": "Pixielity\\Database\\Scripts\\DatabaseScripts::status",
    "db:seed": "Pixielity\\Database\\Scripts\\DatabaseScripts::seed",
    "db:fresh": "Pixielity\\Database\\Scripts\\DatabaseScripts::freshAndSeed",
    "_cache": "── CACHE ───────────────────────────────────────────────",
    "cache:clear": "Pixielity\\Foundation\\Scripts\\CacheScripts::clear",
    "cache:warm": "Pixielity\\Foundation\\Scripts\\CacheScripts::warm",
    "cache:clean": "Pixielity\\Foundation\\Scripts\\CacheScripts::clean",
    "_test": "── TESTING ─────────────────────────────────────────────",
    "test": "Pixielity\\Foundation\\Scripts\\TestScripts::run",
    "test:coverage": "Pixielity\\Foundation\\Scripts\\TestScripts::coverage",
    "test:parallel": "Pixielity\\Foundation\\Scripts\\TestScripts::parallel",
    "test:filter": "Pixielity\\Foundation\\Scripts\\TestScripts::filter",
    "_quality": "── CODE QUALITY ────────────────────────────────────────",
    "lint": "Pixielity\\Foundation\\Scripts\\LintScripts::check",
    "lint:fix": "Pixielity\\Foundation\\Scripts\\LintScripts::fix",
    "analyse": "Pixielity\\Foundation\\Scripts\\AnalyseScripts::run",
    "analyse:baseline": "Pixielity\\Foundation\\Scripts\\AnalyseScripts::baseline",
    "refactor": "Pixielity\\Foundation\\Scripts\\RefactorScripts::dryRun",
    "refactor:fix": "Pixielity\\Foundation\\Scripts\\RefactorScripts::apply",
    "insights": "Pixielity\\Foundation\\Scripts\\InsightsScripts::run",
    "insights:fix": "Pixielity\\Foundation\\Scripts\\InsightsScripts::fix",
    "quality": [
      "@lint",
      "@analyse",
      "@test"
    ],
    "quality:fix": [
      "@lint:fix",
      "@refactor:fix",
      "@analyse"
    ],
    "_repos": "── REPOSITORY MANAGEMENT ───────────────────────────────",
    "repos:sync": "Pixielity\\Scripts\\ComposerScripts::reposSync",
    "repos:check": "Pixielity\\Scripts\\ComposerScripts::reposCheck",
    "_docker": "── DOCKER ──────────────────────────────────────────────",
    "docker:check": "Pixielity\\Docker\\Scripts\\DockerScripts::check",
    "docker:up": "Pixielity\\Docker\\Scripts\\DockerScripts::up",
    "docker:up:kill": "Pixielity\\Docker\\Scripts\\DockerScripts::upKill",
    "docker:up:orbstack": "Pixielity\\Docker\\Scripts\\DockerScripts::upOrbstack",
    "docker:down": "Pixielity\\Docker\\Scripts\\DockerScripts::down",
    "docker:down:clean": "Pixielity\\Docker\\Scripts\\DockerScripts::downClean",
    "docker:restart": "Pixielity\\Docker\\Scripts\\DockerScripts::restart",
    "docker:logs": "Pixielity\\Docker\\Scripts\\DockerScripts::logs",
    "docker:ps": "Pixielity\\Docker\\Scripts\\DockerScripts::ps",
    "docker:build": "Pixielity\\Docker\\Scripts\\DockerScripts::build",
    "docker:clean": "Pixielity\\Docker\\Scripts\\DockerScripts::clean"
  },
  "extra": {
    "laravel": {
      "dont-discover": [
        "pixielity/octane-module"
      ]
    },
    "composer-attribute-collector": {
      "include": [
        "{vendor}/pixielity/laravel-framework/src/*/src",
        "{vendor}/pixielity/laravel-foundation/src/Controllers",
        "{vendor}/pixielity/laravel-foundation/src/Concerns",
        "{vendor}/pixielity/laravel-foundation/src/Contracts",
        "{vendor}/pixielity/laravel-foundation/src/Traits",
        "modules/framework/src/*/src",
        "modules/foundation/src/Controllers"
      ]
    }
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true,
    "allow-plugins": {
      "olvlvl/composer-attribute-collector": true,
      "pestphp/pest-plugin": true,
      "php-http/discovery": true,
      "wikimedia/composer-merge-plugin": true,
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "repositories": [
    {
      "type": "path",
      "url": "../../modules/framework",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../modules/foundation",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../modules/octane",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../modules/user",
      "options": {
        "symlink": true
      }
    }
  ],
  "scripts-descriptions": {
    "_setup": "── SETUP ───────────────────────────────────────────",
    "setup": "Full setup: env + Docker + install + key:generate + migrate",
    "setup:env": "Copy .env templates and create symlinks via bin/setup-env",
    "setup:quick": "Quick setup without Docker (install + env + key:generate)",
    "_env": "── ENVIRONMENT ─────────────────────────────────────",
    "env:dev": "Switch to dev (stability=dev, APP_ENV=local, array drivers)",
    "env:testing": "Switch to testing (in-memory SQLite, array drivers)",
    "env:prod": "Switch to production (stability=stable, Redis, SMTP, debug off)",
    "env:status": "Show current environment: stability + key .env vars",
    "_dev": "── DEV SERVERS ─────────────────────────────────────",
    "dev": "Start Laravel dev server (php artisan serve)",
    "dev:octane": "Start Octane dev server with FrankenPHP + file watcher",
    "dev:full": "Start Octane + queue worker + Pail log viewer concurrently",
    "_octane": "── OCTANE ──────────────────────────────────────────",
    "octane:start": "Start Octane (dev, FrankenPHP + watch, reads OCTANE_* env vars)",
    "octane:start:prod": "Cache config/routes/events then start Octane for production",
    "octane:reload": "Reload Octane workers without downtime (use after deploy)",
    "octane:stop": "Stop the running Octane server",
    "octane:status": "Show Octane server status",
    "_database": "── DATABASE ────────────────────────────────────────",
    "migrate": "Run pending database migrations",
    "migrate:fresh": "Drop all tables, re-run migrations, and seed",
    "migrate:rollback": "Rollback the last migration batch (pass --step=N after --)",
    "migrate:status": "Show the status of each migration",
    "db:seed": "Seed the database (pass --class=X after -- for specific seeder)",
    "db:fresh": "Alias for migrate:fresh — drop, migrate, and seed",
    "_cache": "── CACHE ───────────────────────────────────────────",
    "cache:clear": "Flush all caches (cache:flush --force)",
    "cache:warm": "Cache config, routes, and events for production",
    "cache:clean": "Clean specific cache types (pass types after --)",
    "_test": "── TESTING ─────────────────────────────────────────",
    "test": "Clear config cache then run the full test suite",
    "test:coverage": "Run tests with Clover XML coverage report",
    "test:parallel": "Run tests in parallel",
    "test:filter": "Run tests matching a pattern (pass pattern after --)",
    "_quality": "── CODE QUALITY ────────────────────────────────────",
    "lint": "Check code style with Pint (read-only, CI-safe)",
    "lint:fix": "Fix code style issues with Pint",
    "analyse": "Run PHPStan static analysis (512M memory limit)",
    "analyse:baseline": "Generate PHPStan baseline to suppress existing errors",
    "refactor": "Preview Rector refactoring changes (dry-run, no files modified)",
    "refactor:fix": "Apply Rector refactoring changes (modifies files)",
    "insights": "Run PHP Insights quality analysis (Code/Complexity/Architecture/Style)",
    "insights:fix": "Run PHP Insights and apply safe auto-fixes",
    "quality": "Run all quality checks: lint + analyse + test",
    "quality:fix": "Fix all quality issues: lint:fix + refactor:fix + analyse",
    "_repos": "── REPOSITORY MANAGEMENT ───────────────────────────",
    "repos:sync": "Add missing local module path repositories to composer.json",
    "repos:check": "Dry-run: list required local modules missing from repositories",
    "_docker": "── DOCKER ──────────────────────────────────────────",
    "docker:check": "Check if required ports are available before starting",
    "docker:up": "Start all Docker services",
    "docker:up:kill": "Start Docker services, killing processes on conflicting ports",
    "docker:up:orbstack": "Start Docker services using OrbStack (macOS)",
    "docker:down": "Stop all Docker services",
    "docker:down:clean": "Stop Docker services and remove all volumes (deletes data)",
    "docker:restart": "Restart all Docker services",
    "docker:logs": "Follow Docker service logs",
    "docker:ps": "List running Docker containers",
    "docker:build": "Build the application Docker image (no cache)",
    "docker:clean": "Remove all containers, networks, and volumes"
  }
}
