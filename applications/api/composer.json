{
  "$schema": "https://getcomposer.org/schema.json",
  "name": "pixielity/api-app",
  "type": "project",
  "description": "Laravel 13 application — api-app.",
  "keywords": [
    "laravel",
    "framework",
    "application"
  ],
  "homepage": "https://github.com/pixielity-inc/php-monorepo",
  "license": "MIT",
  "authors": [
    {
      "name": "Your Name",
      "email": "you@example.com",
      "role": "Developer"
    }
  ],
  "require": {
    "php": "^8.4",
    "laravel/framework": "^13.0",
    "laravel/tinker": "^3.0",
    "nwidart/laravel-modules": "^13.0",
    "pixielity/laravel-framework": "*",
    "pixielity/laravel-foundation": "*",
    "pixielity/laravel-octane": "*",
    "pixielity/laravel-user": "*"
  },
  "require-dev": {
    "barryvdh/laravel-debugbar": "^4.1",
    "driftingly/rector-laravel": "^2.2",
    "fakerphp/faker": "^1.23",
    "larastan/larastan": "^3.9",
    "laravel/boost": "^2.0",
    "laravel/pail": "^1.2.5",
    "laravel/pint": "^1.29",
    "mockery/mockery": "^1.6",
    "nunomaduro/collision": "^8.6",
    "nunomaduro/phpinsights": "^2.14",
    "pestphp/pest": "^4.4",
    "pestphp/pest-plugin-laravel": "^4.1",
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^12.5.12",
    "rector/rector": "^2.3",
    "spatie/laravel-ray": "^1.43"
  },
  "suggest": {
    "laravel/cashier": "Stripe billing and subscription management",
    "laravel/cashier-paddle": "Paddle billing integration",
    "laravel/dusk": "Browser automation and testing",
    "laravel/envoy": "Task runner for remote servers",
    "laravel/folio": "Page-based routing for Laravel",
    "laravel/jetstream": "Application scaffolding with auth, teams, and more",
    "laravel/octane": "Supercharge application performance with Swoole or RoadRunner",
    "laravel/passport": "Full OAuth2 server implementation",
    "laravel/pennant": "Feature flags management",
    "laravel/pulse": "Real-time application performance monitoring",
    "laravel/reverb": "First-party WebSocket server",
    "laravel/scout": "Full-text search via Algolia, Meilisearch, or Typesense",
    "laravel/socialite": "OAuth authentication with social providers",
    "laravel/telescope": "Debug assistant and request inspector",
    "spatie/laravel-activitylog": "Log activity inside your Laravel app",
    "spatie/laravel-backup": "Back up your application",
    "spatie/laravel-medialibrary": "Associate files with Eloquent models",
    "spatie/laravel-permission": "Role and permission management",
    "spatie/laravel-query-builder": "Easily build Eloquent queries from API requests",
    "spatie/laravel-sluggable": "Generate slugs for Eloquent models",
    "spatie/laravel-translatable": "Making Eloquent models translatable",
    "barryvdh/laravel-ide-helper": "IDE helper for Laravel facades and models",
    "pestphp/pest": "Elegant PHP testing framework",
    "pestphp/pest-plugin-laravel": "Pest plugin for Laravel"
  },
  "autoload": {
    "files": [
      "vendor/attributes.php"
    ]
  },
  "scripts": {
    "post-install-cmd": [
      "Pixielity\\Scripts\\ComposerScripts::ensureRepositories"
    ],
    "post-update-cmd": [
      "Pixielity\\Scripts\\ComposerScripts::ensureRepositories",
      "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
    ],
    "post-autoload-dump": [
      "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
      "@php artisan package:discover --ansi"
    ],
    "post-root-package-install": [
      "php bin/setup-env"
    ],
    "post-create-project-cmd": [
      "php bin/setup-env",
      "php artisan key:generate --ansi"
    ],
    "pre-package-uninstall": [
      "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
    ],
    "setup": [
      "@setup:env",
      "@docker:up",
      "composer install",
      "php artisan key:generate --ansi",
      "php artisan migrate --force --ansi"
    ],
    "setup:env": [
      "php bin/setup-env"
    ],
    "setup:quick": [
      "composer install",
      "php bin/setup-env",
      "php artisan key:generate --ansi"
    ],
    "dev": [
      "Composer\\Config::disableProcessTimeout",
      "php artisan serve"
    ],
    "dev:octane": [
      "Composer\\Config::disableProcessTimeout",
      "php artisan octane:start --server=frankenphp --watch"
    ],
    "dev:full": [
      "Composer\\Config::disableProcessTimeout",
      "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185\" \"php artisan octane:start --server=frankenphp --watch\" \"php artisan queue:listen --tries=1 --timeout=0\" \"php artisan pail --timeout=0\" --names=octane,queue,logs --kill-others"
    ],
    "octane:start": "Pixielity\\Octane\\Scripts\\OctaneScripts::start",
    "octane:start:prod": "Pixielity\\Octane\\Scripts\\OctaneScripts::startProd",
    "octane:reload": "Pixielity\\Octane\\Scripts\\OctaneScripts::reload",
    "octane:stop": "Pixielity\\Octane\\Scripts\\OctaneScripts::stop",
    "migrate": "Pixielity\\Database\\Scripts\\DatabaseScripts::migrate",
    "migrate:fresh": "Pixielity\\Database\\Scripts\\DatabaseScripts::fresh",
    "migrate:rollback": "Pixielity\\Database\\Scripts\\DatabaseScripts::rollback",
    "db:seed": "Pixielity\\Database\\Scripts\\DatabaseScripts::seed",
    "test": "Pixielity\\Foundation\\Scripts\\TestScripts::run",
    "test:coverage": "Pixielity\\Foundation\\Scripts\\TestScripts::coverage",
    "test:parallel": "Pixielity\\Foundation\\Scripts\\TestScripts::parallel",
    "lint": "vendor/bin/pint --test",
    "lint:fix": "vendor/bin/pint",
    "analyse": "vendor/bin/phpstan analyse --memory-limit=512M --no-progress",
    "analyse:baseline": "vendor/bin/phpstan analyse --memory-limit=512M --generate-baseline",
    "refactor": "vendor/bin/rector process --dry-run",
    "refactor:fix": "vendor/bin/rector process",
    "insights": [
      "vendor/bin/phpinsights analyse --no-interaction"
    ],
    "insights:fix": [
      "vendor/bin/phpinsights analyse --fix --no-interaction"
    ],
    "quality": [
      "@lint",
      "@analyse",
      "@test"
    ],
    "quality:fix": [
      "@lint:fix",
      "@refactor:fix",
      "@analyse"
    ],
    "env:dev": "Pixielity\\Scripts\\ComposerScripts::envDev",
    "env:testing": "Pixielity\\Scripts\\ComposerScripts::envTesting",
    "env:prod": "Pixielity\\Scripts\\ComposerScripts::envProd",
    "env:status": "Pixielity\\Scripts\\ComposerScripts::envStatus",
    "repos:sync": "Pixielity\\Scripts\\ComposerScripts::reposSync",
    "repos:check": "Pixielity\\Scripts\\ComposerScripts::reposCheck",
    "docker:check": [
      "bash bin/docker-check-ports"
    ],
    "docker:up": [
      "bash bin/docker-up"
    ],
    "docker:up:kill": [
      "bash bin/docker-up --kill"
    ],
    "docker:up:orbstack": [
      "bash bin/docker-up --orbstack"
    ],
    "docker:down": [
      "bash bin/docker-down"
    ],
    "docker:down:clean": [
      "bash bin/docker-down --volumes"
    ],
    "docker:restart": [
      "docker-compose -f docker/docker-compose.yml restart"
    ],
    "docker:logs": [
      "docker-compose -f docker/docker-compose.yml logs -f"
    ],
    "docker:ps": [
      "docker-compose -f docker/docker-compose.yml ps"
    ],
    "docker:build": [
      "docker-compose -f docker/compose.app.yml build --no-cache app"
    ],
    "docker:clean": [
      "docker-compose -f docker/docker-compose.yml down -v --remove-orphans"
    ],
    "octane:status": "Pixielity\\Octane\\Scripts\\OctaneScripts::status",
    "cache:clear": "Pixielity\\Foundation\\Scripts\\CacheScripts::clear",
    "cache:warm": "Pixielity\\Foundation\\Scripts\\CacheScripts::warm",
    "cache:clean": "Pixielity\\Foundation\\Scripts\\CacheScripts::clean",
    "test:filter": "Pixielity\\Foundation\\Scripts\\TestScripts::filter",
    "migrate:status": "Pixielity\\Database\\Scripts\\DatabaseScripts::status",
    "db:fresh": "Pixielity\\Database\\Scripts\\DatabaseScripts::freshAndSeed"
  },
  "extra": {
    "laravel": {
      "dont-discover": [
        "pixielity/octane-module"
      ]
    },
    "composer-attribute-collector": {
      "include": [
        "{vendor}/pixielity/laravel-framework/src/*/src",
        "{vendor}/pixielity/laravel-foundation/src/Controllers",
        "{vendor}/pixielity/laravel-foundation/src/Concerns",
        "{vendor}/pixielity/laravel-foundation/src/Contracts",
        "{vendor}/pixielity/laravel-foundation/src/Traits",
        "modules/framework/src/*/src",
        "modules/foundation/src/Controllers"
      ]
    }
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true,
    "allow-plugins": {
      "olvlvl/composer-attribute-collector": true,
      "pestphp/pest-plugin": true,
      "php-http/discovery": true,
      "wikimedia/composer-merge-plugin": true,
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "autoload-dev": {
    "psr-4": {
      "Pixielity\\Scripts\\": "../../scripts/"
    }
  },
  "repositories": [
    {
      "type": "path",
      "url": "../../modules/framework",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../modules/foundation",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../modules/octane",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../modules/user",
      "options": {
        "symlink": true
      }
    }
  ],
  "scripts-descriptions": {
    "setup": "Full setup: env + Docker + install + key + migrate",
    "setup:env": "Copy and configure .env from template",
    "setup:quick": "Quick setup without Docker",
    "dev": "Start Laravel dev server (php artisan serve)",
    "dev:octane": "Start Octane dev server with FrankenPHP + watch",
    "dev:full": "Start Octane + queue + pail concurrently",
    "octane:start": "Start Octane dev server (FrankenPHP + watch, reads OCTANE_SERVER/HOST/PORT)",
    "octane:start:prod": "Cache config/routes/events then start Octane for production",
    "octane:reload": "Reload Octane workers without downtime (use after deploy)",
    "octane:stop": "Stop the running Octane server",
    "migrate": "Run pending database migrations",
    "migrate:fresh": "Drop all tables and re-run migrations with seeders",
    "migrate:rollback": "Rollback the last migration batch",
    "db:seed": "Seed the database",
    "optimize": "Cache config, routes, and events for production",
    "optimize:clear": "Clear all application caches",
    "test": "Clear config cache then run the full test suite",
    "test:coverage": "Run tests with Clover XML coverage report",
    "test:parallel": "Run tests in parallel",
    "lint": "Check code style with Laravel Pint (no fix)",
    "lint:fix": "Fix code style issues with Laravel Pint",
    "analyse": "Run PHPStan static analysis",
    "analyse:baseline": "Generate PHPStan baseline file",
    "refactor": "Preview Rector refactoring changes (dry-run)",
    "refactor:fix": "Apply Rector refactoring changes",
    "insights": "Run PHP Insights quality analysis",
    "insights:fix": "Run PHP Insights and apply fixes",
    "quality": "Run all quality checks: lint + analyse + test",
    "quality:fix": "Fix all quality issues: lint:fix + refactor:fix + analyse",
    "env:dev": "Switch to dev environment (stability, .env, path repos)",
    "env:testing": "Switch to testing environment",
    "env:prod": "Switch to production environment",
    "env:status": "Show current environment status",
    "repos:sync": "Add missing local module path repositories",
    "repos:check": "Dry-run: list unregistered local module paths",
    "docker:check": "Check if required ports are available",
    "docker:up": "Start Docker services",
    "docker:up:kill": "Start Docker services, killing conflicting processes",
    "docker:up:orbstack": "Start Docker services using OrbStack",
    "docker:down": "Stop Docker services",
    "docker:down:clean": "Stop Docker services and remove volumes",
    "docker:restart": "Restart all Docker services",
    "docker:logs": "Follow Docker service logs",
    "docker:ps": "List running Docker containers",
    "docker:build": "Build the application Docker image",
    "docker:clean": "Remove all containers, networks, and volumes",
    "octane:status": "Show Octane server status",
    "cache:clear": "Flush all caches using cache:flush --force",
    "cache:warm": "Cache config, routes, and events for production",
    "cache:clean": "Clean specific cache types (pass types after --)",
    "test:filter": "Run tests matching a filter (pass pattern after --)",
    "migrate:status": "Show the status of each migration",
    "db:fresh": "Drop all tables, migrate, and seed"
  }
}
