# ==============================================================================
# Laravel Application Configuration
# ==============================================================================
# Application-level settings for Laravel
# Docker infrastructure settings are in .env.docker
# ==============================================================================

# ==============================================================================
# APPLICATION
# ==============================================================================

APP_NAME=Laravel
APP_ENV=local
APP_KEY=base64:1Xx46J3lrvpqCVhkprlLwBCothivtGIBQHTYyKaIwQk=
APP_DEBUG=true
APP_URL=http://localhost:8000
ASSET_URL=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=cache
APP_MAINTENANCE_STORE=redis

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# ==============================================================================
# LOGGING
# ==============================================================================

LOG_CHANNEL=stack
LOG_STACK=daily,stderr
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info
LOG_DAILY_DAYS=14

# ==============================================================================
# DATABASE - POSTGRESQL (Docker Container)
# ==============================================================================
# NOTE: Use 127.0.0.1 for local development (host machine)
#       Use 'postgres' only when running Laravel inside a Docker container

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=laravel
DB_USERNAME=laravel
DB_PASSWORD=secret
DB_CHARSET=utf8
DB_SEARCH_PATH=public
DB_SSLMODE=prefer
DB_TIMEOUT=30
DB_PERSISTENT=false

# PostgreSQL Admin (pgAdmin)
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin

# ==============================================================================
# DATABASE - MYSQL (Optional - Uncomment to use)
# ==============================================================================
# NOTE: Use 127.0.0.1 for local development (host machine)
#       Use 'mysql' only when running Laravel inside a Docker container

# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=laravel
# DB_PASSWORD=secret
# DB_ROOT_PASSWORD=root_secret

# ==============================================================================
# DATABASE - MONGODB (Optional)
# ==============================================================================
# NOTE: Use 127.0.0.1 for local development (host machine)
#       Use 'mongodb' only when running Laravel inside a Docker container

# MONGODB_HOST=127.0.0.1
# MONGODB_PORT=27017
# MONGODB_DATABASE=laravel
# MONGODB_USERNAME=root
# MONGODB_PASSWORD=secret

# ==============================================================================
# SESSION & CACHE
# ==============================================================================

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SESSION_PARTITIONED_COOKIE=false

CACHE_STORE=redis
CACHE_PREFIX=laravel_cache
CACHE_SERIALIZABLE_CLASSES=false

# ==============================================================================
# REDIS (Docker Container)
# ==============================================================================
# NOTE: Use 127.0.0.1 for local development (host machine)
#       Use 'redis' only when running Laravel inside a Docker container

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=redis_password
REDIS_PORT=6379
REDIS_DB=0
REDIS_PREFIX=laravel_database
REDIS_PERSISTENT=true
REDIS_TIMEOUT=5.0
REDIS_READ_TIMEOUT=5.0

# Redis Cache Database
REDIS_CACHE_DB=1

# Redis Queue Database
REDIS_QUEUE_DB=2
REDIS_QUEUE_RETRY_AFTER=90
REDIS_QUEUE_BLOCK_FOR=5

# ==============================================================================
# QUEUE & JOBS
# ==============================================================================

QUEUE_CONNECTION=redis
QUEUE_FAILED_DRIVER=database-uuids
QUEUE_AFTER_COMMIT=false

# ==============================================================================
# BROADCASTING
# ==============================================================================

BROADCAST_CONNECTION=reverb

# ==============================================================================
# FILESYSTEM & STORAGE
# ==============================================================================

FILESYSTEM_DISK=s3
FILESYSTEM_THROW=false
FILESYSTEM_REPORT=false

# MinIO S3-Compatible Storage (Docker Container)
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=laravel
AWS_ENDPOINT=http://minio:9000
AWS_USE_PATH_STYLE_ENDPOINT=true
AWS_URL=http://localhost:9000/laravel
AWS_VISIBILITY=private

# ==============================================================================
# MAIL (Docker Container - Mailpit)
# ==============================================================================
# NOTE: Use 127.0.0.1 for local development (host machine)
#       Use 'mailpit' only when running Laravel inside a Docker container

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_TIMEOUT=30
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ==============================================================================
# SEARCH - MEILISEARCH (Docker Container)
# ==============================================================================
# NOTE: Use http://127.0.0.1:7700 for local development (host machine)
#       Use http://meilisearch:7700 only when running Laravel inside a Docker container

MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_KEY=masterKeySecure123456

# ==============================================================================
# SEARCH - ELASTICSEARCH (Optional)
# ==============================================================================

# ELASTICSEARCH_HOST=http://elasticsearch:9200
# ELASTICSEARCH_USERNAME=elastic
# ELASTICSEARCH_PASSWORD=elastic

# ==============================================================================
# WEBSOCKETS - LARAVEL REVERB (Docker Container)
# ==============================================================================

REVERB_APP_ID=app-id
REVERB_APP_KEY=app-key
REVERB_APP_SECRET=app-secret
REVERB_HOST=reverb
REVERB_PORT=6001
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# ==============================================================================
# MESSAGE BROKER - KAFKA (Optional)
# ==============================================================================

# KAFKA_BROKERS=kafka:9092
# KAFKA_CONSUMER_GROUP_ID=laravel
# KAFKA_SASL_USERNAME=
# KAFKA_SASL_PASSWORD=
# KAFKA_SASL_MECHANISMS=

# ==============================================================================
# MESSAGE BROKER - RABBITMQ (Optional)
# ==============================================================================

# RABBITMQ_HOST=rabbitmq
# RABBITMQ_PORT=5672
# RABBITMQ_USER=guest
# RABBITMQ_PASSWORD=guest
# RABBITMQ_VHOST=/

# ==============================================================================
# VITE
# ==============================================================================

VITE_APP_NAME="${APP_NAME}"

# ==============================================================================
# API CONFIGURATION
# ==============================================================================

# Authentication
AUTH_GUARD=sanctum
AUTH_PASSWORD_RESET_EXPIRE=30
AUTH_PASSWORD_RESET_THROTTLE=60
AUTH_PASSWORD_TIMEOUT=3600

# CORS (Cross-Origin Resource Sharing)
CORS_ALLOWED_ORIGINS=*
CORS_MAX_AGE=0
CORS_SUPPORTS_CREDENTIALS=false

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_AUTHENTICATED=1000

# API Versioning
API_VERSION=v1
API_PREFIX=api

# ==============================================================================
# THIRD-PARTY SERVICES
# ==============================================================================

# Add your third-party service credentials here
# STRIPE_KEY=
# STRIPE_SECRET=
# PUSHER_APP_ID=
# PUSHER_APP_KEY=
# PUSHER_APP_SECRET=
# PUSHER_APP_CLUSTER=mt1
