#!/usr/bin/env bash

# ==============================================================================
# Docker Down - Stop Docker Containers
# ==============================================================================
# Stops and optionally removes Docker containers and volumes
#
# Usage:
#   ./bin/docker-down                  # Stop containers
#   ./bin/docker-down --volumes        # Stop and remove volumes
#   ./bin/docker-down --orbstack       # Use OrbStack config
# ==============================================================================

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Script directory
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

# Parse arguments
REMOVE_VOLUMES=false
USE_ORBSTACK=false
COMPOSE_FILES="-f docker/docker-compose.yml"

for arg in "$@"; do
    case $arg in
        --volumes|-v)
            REMOVE_VOLUMES=true
            ;;
        --orbstack|-o)
            USE_ORBSTACK=true
            ;;
        --help|-h)
            echo "Usage: $0 [OPTIONS]"
            echo ""
            echo "Options:"
            echo "  --volumes, -v     Remove volumes (WARNING: deletes all data)"
            echo "  --orbstack, -o    Use OrbStack configuration"
            echo "  --help, -h        Show this help message"
            exit 0
            ;;
    esac
done

# Add OrbStack config if requested
if [ "$USE_ORBSTACK" = true ]; then
    COMPOSE_FILES="$COMPOSE_FILES -f docker/docker-compose.orbstack.yml"
fi

echo -e "${BLUE}==============================================================================${NC}"
echo -e "${BLUE}Docker Down - Stopping Containers${NC}"
echo -e "${BLUE}==============================================================================${NC}"
echo ""

cd "$PROJECT_ROOT"

# Build docker-compose command
COMPOSE_CMD="docker-compose $COMPOSE_FILES down"

if [ "$REMOVE_VOLUMES" = true ]; then
    echo -e "${RED}WARNING: This will remove all volumes and delete all data!${NC}"
    echo -e "${YELLOW}Are you sure? [y/N]${NC}"
    read -r response
    if [[ ! "$response" =~ ^[Yy]$ ]]; then
        echo -e "${BLUE}Cancelled${NC}"
        exit 0
    fi
    COMPOSE_CMD="$COMPOSE_CMD -v"
fi

echo -e "${YELLOW}Running: $COMPOSE_CMD${NC}"
echo ""

if $COMPOSE_CMD; then
    echo ""
    echo -e "${GREEN}==============================================================================${NC}"
    echo -e "${GREEN}✓ Docker containers stopped successfully!${NC}"
    echo -e "${GREEN}==============================================================================${NC}"
    echo ""
    
    if [ "$REMOVE_VOLUMES" = true ]; then
        echo -e "${YELLOW}All volumes have been removed. Data has been deleted.${NC}"
    else
        echo -e "${BLUE}Volumes preserved. Data is safe.${NC}"
        echo -e "${YELLOW}To remove volumes and delete all data:${NC}"
        echo -e "${BLUE}  $0 --volumes${NC}"
    fi
    echo ""
else
    echo ""
    echo -e "${RED}==============================================================================${NC}"
    echo -e "${RED}✗ Failed to stop Docker containers${NC}"
    echo -e "${RED}==============================================================================${NC}"
    echo ""
    exit 1
fi
