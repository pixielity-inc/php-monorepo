#!/usr/bin/env bash

# ==============================================================================
# Docker Up - Smart Docker Compose Starter
# ==============================================================================
# Checks ports, handles conflicts, and starts Docker containers
#
# Usage:
#   ./bin/docker-up                    # Check ports and start
#   ./bin/docker-up --kill             # Kill conflicts and start
#   ./bin/docker-up --kill --yes       # Kill without confirmation
#   ./bin/docker-up --orbstack         # Use OrbStack config (macOS)
#   ./bin/docker-up --skip-check       # Skip port checking
# ==============================================================================

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Script directory
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

# Parse arguments
KILL_PROCESSES=false
AUTO_YES=false
USE_ORBSTACK=false
SKIP_CHECK=false
COMPOSE_FILES="-f docker/docker-compose.yml"

for arg in "$@"; do
    case $arg in
        --kill|-k)
            KILL_PROCESSES=true
            ;;
        --yes|-y)
            AUTO_YES=true
            ;;
        --orbstack|-o)
            USE_ORBSTACK=true
            ;;
        --skip-check|-s)
            SKIP_CHECK=true
            ;;
        --help|-h)
            echo "Usage: $0 [OPTIONS]"
            echo ""
            echo "Options:"
            echo "  --kill, -k        Kill processes using conflicting ports"
            echo "  --yes, -y         Auto-confirm killing processes (use with --kill)"
            echo "  --orbstack, -o    Use OrbStack configuration (macOS only)"
            echo "  --skip-check, -s  Skip port checking"
            echo "  --help, -h        Show this help message"
            exit 0
            ;;
    esac
done

# Add OrbStack config if requested
if [ "$USE_ORBSTACK" = true ]; then
    COMPOSE_FILES="$COMPOSE_FILES -f docker/docker-compose.orbstack.yml"
fi

echo -e "${BLUE}==============================================================================${NC}"
echo -e "${BLUE}Docker Up - Starting Containers${NC}"
echo -e "${BLUE}==============================================================================${NC}"
echo ""

# Check ports unless skipped
if [ "$SKIP_CHECK" = false ]; then
    echo -e "${YELLOW}Step 1: Checking ports...${NC}"
    echo ""
    
    CHECK_ARGS=""
    if [ "$KILL_PROCESSES" = true ]; then
        CHECK_ARGS="--kill"
    fi
    if [ "$AUTO_YES" = true ]; then
        CHECK_ARGS="$CHECK_ARGS --yes"
    fi
    
    if ! "$SCRIPT_DIR/docker-check-ports" $CHECK_ARGS; then
        echo ""
        echo -e "${RED}Port conflicts detected. Please resolve them and try again.${NC}"
        echo -e "${YELLOW}Or run with --kill to automatically kill conflicting processes:${NC}"
        echo -e "${BLUE}  $0 --kill${NC}"
        exit 1
    fi
    
    echo ""
fi

# Start Docker containers
echo -e "${YELLOW}Step 2: Starting Docker containers...${NC}"
echo ""
echo -e "${BLUE}Running: docker-compose $COMPOSE_FILES up -d${NC}"
echo ""

cd "$PROJECT_ROOT"

if docker-compose $COMPOSE_FILES up -d; then
    echo ""
    echo -e "${GREEN}==============================================================================${NC}"
    echo -e "${GREEN}✓ Docker containers started successfully!${NC}"
    echo -e "${GREEN}==============================================================================${NC}"
    echo ""
    
    # Show running containers
    echo -e "${BLUE}Running containers:${NC}"
    docker-compose $COMPOSE_FILES ps
    
    echo ""
    echo -e "${GREEN}Access your services:${NC}"
    
    # Load env to show URLs
    if [ -f "docker/.env.docker" ]; then
        set -a
        source "docker/.env.docker"
        set +a
        
        echo -e "${BLUE}  Application:    ${NC}http://localhost:${APP_PORT:-8000}"
        echo -e "${BLUE}  pgAdmin:        ${NC}http://localhost:${PGADMIN_PORT:-5050}"
        echo -e "${BLUE}  Mailpit:        ${NC}http://localhost:${MAILPIT_UI_PORT:-8025}"
        echo -e "${BLUE}  MinIO Console:  ${NC}http://localhost:${MINIO_CONSOLE_PORT:-9001}"
        echo -e "${BLUE}  Meilisearch:    ${NC}http://localhost:${MEILISEARCH_PORT:-7700}"
        
        if [ "$USE_ORBSTACK" = true ]; then
            echo ""
            echo -e "${GREEN}OrbStack domains:${NC}"
            echo -e "${BLUE}  Application:    ${NC}http://${APP_DOMAIN:-laravel}${DOMAIN_LTD:-.local}"
            echo -e "${BLUE}  pgAdmin:        ${NC}http://${PGADMIN_DOMAIN:-pgadmin}${DOMAIN_LTD:-.local}"
            echo -e "${BLUE}  Mailpit:        ${NC}http://${MAILPIT_DOMAIN:-mailpit}${DOMAIN_LTD:-.local}"
        fi
    fi
    
    echo ""
    echo -e "${YELLOW}To stop containers:${NC}"
    echo -e "${BLUE}  docker-compose $COMPOSE_FILES down${NC}"
    echo ""
    echo -e "${YELLOW}To view logs:${NC}"
    echo -e "${BLUE}  docker-compose $COMPOSE_FILES logs -f${NC}"
    echo ""
else
    echo ""
    echo -e "${RED}==============================================================================${NC}"
    echo -e "${RED}✗ Failed to start Docker containers${NC}"
    echo -e "${RED}==============================================================================${NC}"
    echo ""
    echo -e "${YELLOW}Check the error messages above for details.${NC}"
    echo ""
    exit 1
fi
