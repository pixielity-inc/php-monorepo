# =============================================================================
# .gitignore — php-monorepo
# =============================================================================
# Rules are grouped by category. More specific rules override broader ones.
# Use `git check-ignore -v <file>` to debug why a file is ignored.

# -----------------------------------------------------------------------------
# Node / npm
# -----------------------------------------------------------------------------
node_modules/
.pnp
.pnp.js
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# -----------------------------------------------------------------------------
# Turborepo
# -----------------------------------------------------------------------------
.turbo/

# -----------------------------------------------------------------------------
# Build outputs
# -----------------------------------------------------------------------------
dist/
build/
out/
.next/
public/build/
public/hot/

# -----------------------------------------------------------------------------
# PHP / Composer
# -----------------------------------------------------------------------------
# Vendor directories are never committed — each workspace installs its own.
vendor/
# Composer auth file may contain credentials.
auth.json
# PHPUnit result cache
.phpunit.result.cache
.phpunit.cache/

# -----------------------------------------------------------------------------
# Laravel
# -----------------------------------------------------------------------------
# Environment files — never commit secrets.
.env
.env.local
.env.*.local
# Laravel compiled/cached files
bootstrap/cache/*.php
storage/framework/cache/
storage/framework/sessions/
storage/framework/views/
storage/logs/
# SQLite databases (dev only)
*.sqlite
*.sqlite-shm
*.sqlite-wal
# Laravel Herd / Valet
.herd/

# -----------------------------------------------------------------------------
# Testing / Coverage
# -----------------------------------------------------------------------------
coverage/
*.lcov
clover.xml
coverage.xml

# -----------------------------------------------------------------------------
# IDE / Editor
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Secrets / Certificates
# -----------------------------------------------------------------------------
*.pem
*.key
*.p12
*.pfx

# -----------------------------------------------------------------------------
# Vercel (if used for any JS apps)
# -----------------------------------------------------------------------------
.vercel/
