{
  "name": "pixielity-php-monorepo",
  "version": "0.0.0",
  "description": "Production-ready PHP/Laravel monorepo template powered by Turborepo.",
  "private": true,
  "homepage": "https://github.com/pixielity-inc/php-monorepo#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pixielity-inc/php-monorepo.git"
  },
  "bugs": {
    "url": "https://github.com/pixielity-inc/php-monorepo/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Your Name",
    "email": "you@example.com",
    "url": "https://example.com"
  },
  "workspaces": [
    "applications/*",
    "modules/*"
  ],
  "scripts": {
    "prepare":      "git config core.hooksPath .githooks",
    "build":        "turbo run build",
    "dev":          "turbo run dev",
    "start":        "turbo run start",
    "lint":         "turbo run lint",
    "lint:fix":     "turbo run lint:fix",
    "test":         "turbo run test",
    "test:coverage":"turbo run test:coverage",
    "analyse":      "turbo run analyse",
    "refactor":     "turbo run refactor",
    "refactor:fix": "turbo run refactor:fix",
    "check-types":  "turbo run check-types",
    "format":       "prettier --write \"**/*.{js,ts,json,md,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{js,ts,json,md,yaml,yml}\"",
    "clean":        "turbo run clean",
    "clean:all":    "turbo run clean && rm -rf node_modules",
    "upgrade":      "pnpm update --recursive --latest",
    "repos:sync":   "composer repos:sync:all"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.4",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.33.0"
}
